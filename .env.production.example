# ===========================================
# CONFIGURAÇÃO DE PRODUÇÃO - TRIAL CAMPAIGNS
# ===========================================
# IMPORTANTE: Copie este arquivo para .env.production e configure com valores reais
# NUNCA commite .env.production com senhas reais!

# ---------------------------------------------
# DOMÍNIO E SSL
# ---------------------------------------------
DOMAIN=trial-campaigns.com
ACME_EMAIL=admin@trial-campaigns.com

# ---------------------------------------------
# TRAEFIK DASHBOARD (OPCIONAL)
# ---------------------------------------------
# Gerar senha com: htpasswd -nb admin sua_senha_aqui
# Ou usando Docker: docker run --rm httpd:alpine htpasswd -nb admin sua_senha_aqui
TRAEFIK_AUTH=admin:$$apr1$$xyz123...

# ---------------------------------------------
# BANCO DE DADOS
# ---------------------------------------------
# IMPORTANTE: Gerar senhas fortes!
# Exemplo: openssl rand -base64 32
DB_ROOT_PASSWORD=ALTERE_ESTA_SENHA_ROOT
DB_DATABASE=laravel_production
DB_USERNAME=laravel_user
DB_PASSWORD=ALTERE_ESTA_SENHA_DB

# ---------------------------------------------
# REDIS
# ---------------------------------------------
# Gerar senha forte: openssl rand -base64 32
REDIS_PASSWORD=ALTERE_ESTA_SENHA_REDIS

# ---------------------------------------------
# APLICAÇÃO LARAVEL
# ---------------------------------------------
APP_NAME="Trial Campaigns"
APP_ENV=production
APP_KEY=base64:GERAR_COM_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://${DOMAIN}

LOG_CHANNEL=stack
LOG_LEVEL=error

# ---------------------------------------------
# QUEUE & CACHE
# ---------------------------------------------
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# ---------------------------------------------
# EMAIL (CONFIGURE CONFORME SEU PROVEDOR)
# ---------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@trial-campaigns.com
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------
# BACKUP (OPCIONAL - S3 AWS)
# ---------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=trial-campaigns-backups
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------
# INSTRUÇÕES DE SEGURANÇA
# ---------------------------------------------
# 1. Gerar senhas fortes:
#    openssl rand -base64 32
#
# 2. Gerar hash para Traefik dashboard:
#    docker run --rm httpd:alpine htpasswd -nb admin sua_senha
#
# 3. Gerar APP_KEY do Laravel:
#    docker-compose exec app php artisan key:generate --show
#
# 4. Nunca commitar este arquivo com senhas reais:
#    Adicione .env.production ao .gitignore
#
# 5. Usar Docker Secrets em produção (recomendado):
#    echo "senha_forte" | docker secret create db_password -
